# Mattermost 연동을 위한 토큰 및 설정
MATTERMOST_URL=https://your-mattermost-domain.com
MATTERMOST_TOKEN=your_mattermost_session_token_here
MATTERMOST_CHANNEL_ID=your_channel_id_here

# Outgoing Webhook 토큰 (Mattermost 통합 > 전체 Outgoing Webhook > 생성 시 발급)
OUTGOING_TOKEN=your_outgoing_webhook_token_here

# Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here

# Ngrok Auth Token (https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# 크롤링(crolling.py) 전용 설정
CROLLING_CHANNEL_NAME=your_target_channel_name
TARGET_USER_ID=your_target_user_id_here
MMAUTHTOKEN=your_mattermost_session_token_here
